def listar():
    usuarios = carregar_dados()
    if not usuarios:
        print('nenhum usuário cadastrado. ')
        return
    for i, user in enumerate(usuarios, start=1):
        print(f'{i}. Nome: {user["nome"]} - email: {user["email"]}')



